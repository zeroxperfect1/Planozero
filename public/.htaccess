<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Deshabilitar listado de directorios
  Options -Indexes

  # No reescribir /api/ ni /uploads/
  RewriteRule ^api(/.*)?$ - [L]
  RewriteRule ^uploads(/.*)?$ - [L]

  # Servir solo ARCHIVOS existentes directo (no directorios — van a React SPA)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Todo lo demás (rutas React, directorios como /blog) → React SPA
  RewriteRule ^ /index.html [L]
</IfModule>
