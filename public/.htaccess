# /public_html/.htaccess — React SPA + PHP API passthrough v3

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Excluir explícitamente /api/ — pasar directamente a PHP
  RewriteRule ^api(/.*)?$ - [L]

  # 2. Excluir /uploads/ — archivos estáticos
  RewriteRule ^uploads(/.*)?$ - [L]

  # 3. Si el archivo o directorio existe, servirlo directo
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 4. Todo lo demás → React SPA
  RewriteRule ^ /index.html [L]
</IfModule>
