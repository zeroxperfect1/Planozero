rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Uploads de usuarios autenticados: cada usuario solo accede a su carpeta
    match /uploads/{userId}/{allPaths=**} {
      // Cualquiera puede leer (necesario para mostrar imágenes en el frontend)
      allow read: if true;
      // Solo el propietario puede escribir y eliminar
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Bloquear todo lo demás por defecto
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
